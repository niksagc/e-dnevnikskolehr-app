{
  "entities": {
    "ClassTeacher": {
      "title": "ClassTeacher",
      "description": "Defines the role of a teacher in a class.",
      "type": "object",
      "properties": {
        "classId": { "type": "string", "description": "The ID of the class." },
        "teacherId": { "type": "string", "description": "The ID of the teacher." },
        "role": { "type": "string", "enum": ["main", "assistant"], "description": "The role of the teacher." }
      },
      "required": ["classId", "teacherId", "role"]
    },
    "FinalGrade": {
      "title": "FinalGrade",
      "description": "The final grade of a student in a subject.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "subjectId": { "type": "string" },
        "grade": { "type": "number" },
        "classId": { "type": "string" }
      },
      "required": ["studentId", "subjectId", "grade", "classId"]
    },
    "ClassLock": {
      "title": "ClassLock",
      "description": "Lock status of a class.",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "locked": { "type": "boolean" }
      },
      "required": ["classId", "locked"]
    },
    "ReportCard": {
      "title": "ReportCard",
      "description": "A student's report card.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "classId": { "type": "string" },
        "grades": { "type": "object" },
        "average": { "type": "number" }
      },
      "required": ["studentId", "classId", "grades", "average"]
    }
  },
  "firestore": {
    "/class_teachers/{id}": { "schema": { "$ref": "ClassTeacher" }, "description": "Class teachers." },
    "/final_grades/{id}": { "schema": { "$ref": "FinalGrade" }, "description": "Final grades." },
    "/class_locks/{classId}": { "schema": { "$ref": "ClassLock" }, "description": "Class locks." },
    "/report_cards/{id}": { "schema": { "$ref": "ReportCard" }, "description": "Report cards." }
  }
}
